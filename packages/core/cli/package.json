{
  "name": "@atlaspack/cli",
  "version": "2.15.23",
  "description": "Blazing fast, zero configuration web application bundler",
  "license": "(MIT OR Apache-2.0)",
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/atlassian-labs/atlaspack.git"
  },
  "bin": {
    "atlaspack": "bin/atlaspack.js"
  },
  "main": "./lib/bin.js",
  "source": "./src/bin.ts",
  "types": "./src/bin.ts",
  "scripts": {
    "build:lib": "gulp build --gulpfile ../../../gulpfile.js --cwd ."
  },
  "engines": {
    "node": ">= 16.0.0"
  },
  "dependencies": {
    "@atlaspack/config-default": "19.0.4",
    "@atlaspack/core": "2.38.4",
    "@atlaspack/diagnostic": "2.14.4",
    "@atlaspack/events": "2.14.4",
    "@atlaspack/feature-flags": "2.31.2",
    "@atlaspack/fs": "2.15.57",
    "@atlaspack/logger": "2.14.54",
    "@atlaspack/package-manager": "2.14.62",
    "@atlaspack/reporter-cli": "2.18.4",
    "@atlaspack/reporter-dev-server": "2.14.62",
    "@atlaspack/reporter-tracer": "2.14.62",
    "@atlaspack/utils": "3.4.4",
    "chalk": "^4.1.0",
    "commander": "^8.3.0",
    "get-port": "^5.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.22.11",
    "@atlaspack/babel-register": "2.14.5",
    "rimraf": "^3.0.2"
